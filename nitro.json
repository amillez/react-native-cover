{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["cover"],
  "ios": {
    "iosModuleName": "Cover"
  },
  "android": {
    "androidNamespace": ["cover"],
    "androidCxxLibName": "Cover"
  },
  "autolinking": {
    "Cover": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridCover"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridCover"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
